# ── Telegram ──────────────────────────────────────────
# Get this from @BotFather on Telegram
BOT_TOKEN=your_telegram_bot_token_here

# Your friend's Telegram user ID
# Have them message @userinfobot to get their numeric ID
ALLOWED_USER_ID=123456789

# ── SportyBet ─────────────────────────────────────────
# Your SportyBet registered phone number
SPORTYBET_PHONE=08012345678

# Your SportyBet account password
SPORTYBET_PASSWORD=your_sportybet_password_here

# ── Optional: Telethon User Listener ────────────────────────────
# Enable this to read messages using your personal Telegram account.
TELETHON_ENABLED=0

# Get these from https://my.telegram.org (API development tools)
TELETHON_API_ID=123456
TELETHON_API_HASH=your_telegram_api_hash_here

# Optional: your phone number for first-time Telethon login
TELETHON_PHONE=+2348012345678

# Session filename created locally for Telethon login state
TELETHON_SESSION=sportyclaw_telethon

# Comma-separated chats/groups/usernames to monitor, e.g. @group_a,@group_b
TELETHON_CHATS=@your_group_username

# Optional: reply in source group with placement status (0 or 1)
TELETHON_REPLY_IN_CHAT=0
